rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string
    //   - photoURL: string
    //   - role: string (enum: student, landlord, admin)
    //   - isVerified: boolean
    //   - verificationStatus: string (enum: pending, approved, rejected)
    //   - phoneNumber: string
    //   - createdAt: timestamp
    //
    // Collection: properties
    // Document ID: {propertyId}
    // Fields:
    //   - landlordId: string (required)
    //   - title: string (required)
    //   - description: string
    //   - address: string
    //   - campus: string
    //   - price: number (required)
    //   - type: string (enum: apartment, studio, room, house)
    //   - rooms: number
    //   - amenities: list
    //   - images: list
    //   - status: string (enum: pending, approved, rejected, archived)
    //   - createdAt: timestamp
    //
    // Collection: bookings
    // Document ID: {bookingId}
    // Fields:
    //   - studentId: string (required)
    //   - landlordId: string (required)
    //   - propertyId: string (required)
    //   - status: string (enum: pending, accepted, declined, cancelled)
    //   - moveInDate: string (ISO date)
    //   - createdAt: timestamp
    //
    // Collection: verifications
    // Document ID: {verificationId}
    // Fields:
    //   - landlordId: string (required)
    //   - idUrl: string
    //   - selfieUrl: string
    //   - ownershipDocUrl: string
    //   - status: string (enum: pending, approved, rejected)
    //   - createdAt: timestamp

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "kuteyioluwaloyevincent291@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['student', 'landlord', 'admin'];
    }

    function isValidProperty(data) {
      return data.keys().hasAll(['landlordId', 'title', 'price', 'status']) &&
             data.landlordId is string &&
             data.title is string &&
             data.price is number &&
             data.status in ['pending', 'approved', 'rejected', 'archived'];
    }

    function isValidBooking(data) {
      return data.keys().hasAll(['studentId', 'landlordId', 'propertyId', 'status']) &&
             data.studentId is string &&
             data.landlordId is string &&
             data.propertyId is string &&
             data.status in ['pending', 'accepted', 'declined', 'cancelled'];
    }

    function isValidVerification(data) {
      return data.keys().hasAll(['landlordId', 'status']) &&
             data.landlordId is string &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && (request.resource.data.role != 'admin' || isAdmin());
      allow update: if (isOwner(uid) && request.resource.data.role == resource.data.role) || isAdmin();
    }

    match /properties/{propertyId} {
      allow read: if true; // Publicly readable for students
      allow create: if isAuthenticated() && isValidProperty(request.resource.data) && request.resource.data.landlordId == request.auth.uid;
      allow update: if (isAuthenticated() && resource.data.landlordId == request.auth.uid) || isAdmin();
      allow delete: if isAdmin();
    }

    match /bookings/{bookingId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.landlordId || isAdmin());
      allow create: if isAuthenticated() && isValidBooking(request.resource.data) && request.resource.data.studentId == request.auth.uid;
      allow update: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.landlordId || isAdmin());
    }

    match /verifications/{verificationId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.landlordId || isAdmin());
      allow create: if isAuthenticated() && isValidVerification(request.resource.data) && request.resource.data.landlordId == request.auth.uid;
      allow update: if isAdmin();
    }
  }
}
